<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Si es un archivo o directorio existente, sirve directamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Todo lo demás va a index.php (que redirige a src/index.php)
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
