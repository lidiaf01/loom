# ============================================
# .gitignore - Proyecto Loom
# ============================================

# Archivos de configuración sensibles
src/www/config.php
*.env
.env.local

# Logs
*.log
logs/
*.log.*

# Archivos del sistema
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Dependencias (si se añaden en el futuro)
/vendor/
/node_modules/
composer.lock
package-lock.json
yarn.lock

# Archivos temporales
*.tmp
*.temp
*.cache
*.bak
*.backup

# Archivos de base de datos
*.sql.backup
*.db
*.sqlite

# Archivos de sesión
sessions/

# Archivos de uploads (si se añaden)
uploads/
tmp/

# Archivos de configuración local
config.local.php

